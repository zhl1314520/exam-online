<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.exam.online.mapper.PaperQuestionMapper">

    <resultMap id="PaperQuestionResultMap" type="com.exam.online.entity.PaperQuestion">
        <id property="id" column="id"/>
        <result property="paperId" column="paper_id"/>
        <result property="questionId" column="question_id"/>
        <result property="questionOrder" column="question_order"/>
        <result property="score" column="score"/>
    </resultMap>

    <select id="selectById" resultMap="PaperQuestionResultMap">
        SELECT * FROM paper_question WHERE id = #{id}
    </select>

    <select id="selectByPaperId" resultMap="PaperQuestionResultMap">
        SELECT * FROM paper_question WHERE paper_id = #{paperId} ORDER BY question_order
    </select>

    <select id="selectByQuestionId" resultMap="PaperQuestionResultMap">
        SELECT * FROM paper_question WHERE question_id = #{questionId}
    </select>

    <select id="countByPaperId" resultType="int">
        SELECT COUNT(*) FROM paper_question WHERE paper_id = #{paperId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO paper_question (paper_id, question_id, question_order, score)
        VALUES (#{paperId}, #{questionId}, #{questionOrder}, #{score})
    </insert>

    <update id="updateById">
        UPDATE paper_question SET
            paper_id = #{paperId},
            question_id = #{questionId},
            question_order = #{questionOrder},
            score = #{score}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM paper_question WHERE id = #{id}
    </delete>

    <delete id="deleteByPaperId">
        DELETE FROM paper_question WHERE paper_id = #{paperId}
    </delete>
</mapper>