<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.exam.online.mapper.SubjectMapper">

    <resultMap id="SubjectResultMap" type="com.exam.online.entity.Subject">
        <id property="subjectId" column="subject_id"/>
        <result property="subjectName" column="subject_name"/>
        <result property="subjectCode" column="subject_code"/>
        <result property="departmentId" column="department_id"/>
        <result property="credit" column="credit"/>
        <result property="description" column="description"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="selectById" resultMap="SubjectResultMap">
        SELECT * FROM subject WHERE subject_id = #{subjectId}
    </select>

    <select id="selectBySubjectCode" resultMap="SubjectResultMap">
        SELECT * FROM subject WHERE subject_code = #{subjectCode}
    </select>

    <select id="selectAll" resultMap="SubjectResultMap">
        SELECT * FROM subject ORDER BY create_time DESC
    </select>

    <select id="selectByDepartmentId" resultMap="SubjectResultMap">
        SELECT * FROM subject WHERE department_id = #{departmentId} ORDER BY create_time DESC
    </select>

    <select id="countAll" resultType="int">
        SELECT COUNT(*) FROM subject
    </select>

    <select id="countByDepartmentId" resultType="int">
        SELECT COUNT(*) FROM subject WHERE department_id = #{departmentId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="subjectId">
        INSERT INTO subject (subject_name, subject_code, department_id, credit, description)
        VALUES (#{subjectName}, #{subjectCode}, #{departmentId}, #{credit}, #{description})
    </insert>

    <update id="updateById">
        UPDATE subject SET
            subject_name = #{subjectName},
            subject_code = #{subjectCode},
            department_id = #{departmentId},
            credit = #{credit},
            description = #{description}
        WHERE subject_id = #{subjectId}
    </update>

    <delete id="deleteById">
        DELETE FROM subject WHERE subject_id = #{subjectId}
    </delete>
</mapper>