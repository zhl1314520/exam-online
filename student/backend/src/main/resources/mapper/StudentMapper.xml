<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.exam.student.mapper.StudentMapper">

    <resultMap id="StudentResultMap" type="com.exam.student.entity.Student">
        <id property="studentId" column="student_id"/>
        <result property="studentNo" column="student_no"/>
        <result property="password" column="password"/>
        <result property="realName" column="real_name"/>
        <result property="gender" column="gender"/>
        <result property="classId" column="class_id"/>
        <result property="email" column="email"/>
        <result property="phone" column="phone"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="lastLoginTime" column="last_login_time"/>
        <result property="className" column="class_name"/>
        <result property="departmentId" column="department_id"/>
        <result property="departmentName" column="department_name"/>
    </resultMap>

    <select id="selectById" resultMap="StudentResultMap">
        SELECT s.*, c.class_name, c.department_id, d.department_name
        FROM student s
        LEFT JOIN class c ON s.class_id = c.class_id
        LEFT JOIN department d ON c.department_id = d.department_id
        WHERE s.student_id = #{studentId}
    </select>

    <select id="selectByStudentNo" resultMap="StudentResultMap">
        SELECT s.*, c.class_name, c.department_id, d.department_name
        FROM student s
        LEFT JOIN class c ON s.class_id = c.class_id
        LEFT JOIN department d ON c.department_id = d.department_id
        WHERE s.student_no = #{studentNo}
    </select>

    <update id="updateLastLoginTime">
        UPDATE student SET last_login_time = NOW() WHERE student_id = #{studentId}
    </update>

    <update id="updatePassword">
        UPDATE student SET password = #{password} WHERE student_id = #{studentId}
    </update>
</mapper>
